# ============================================================
# TrustBank Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ============================================================

# ----------------------------------------------------------
# Supabase Configuration (Required)
# ----------------------------------------------------------
# Your Supabase project ID
VITE_SUPABASE_PROJECT_ID="your-project-id"

# The public anonymous (publishable) key — safe for client-side use
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"

# Your Supabase project URL
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# ----------------------------------------------------------
# Server-Side Only (DO NOT prefix with VITE_)
# ----------------------------------------------------------
# These variables must NEVER appear in frontend / client-side code.
# Use them only in Edge Functions, server-side scripts, or CI/CD.

# Supabase service role key — full database access, bypasses RLS
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Database connection string (if needed for server-side tooling)
# DATABASE_URL="postgresql://user:password@host:port/database"

# ----------------------------------------------------------
# Optional: Third-Party Services (server-side only)
# ----------------------------------------------------------
# Payment gateway keys
# PAYMENT_GATEWAY_SECRET_KEY="your-payment-secret-key"
# PAYMENT_GATEWAY_PUBLIC_KEY="your-payment-public-key"

# Email service credentials
# EMAIL_SERVICE_API_KEY="your-email-api-key"

# Cloud storage credentials
# STORAGE_ACCESS_KEY="your-storage-access-key"
# STORAGE_SECRET_KEY="your-storage-secret-key"

# Encryption keys
# ENCRYPTION_KEY="your-encryption-key"

# JWT secret (if using custom JWT outside Supabase Auth)
# JWT_SECRET="your-jwt-secret"

# ----------------------------------------------------------
# Notes
# ----------------------------------------------------------
# - Variables prefixed with VITE_ are exposed to the browser bundle.
#   Only use this prefix for values that are safe to be public.
# - All secret keys, service role keys, and database credentials
#   must remain server-side only (no VITE_ prefix).
# - Ensure Row Level Security (RLS) is enabled on all Supabase tables.
